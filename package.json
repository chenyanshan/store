{
  "name": "retail-case-database",
  "version": "0.1.0",
  "private": true,
  "description": "Case database website for Cloudflare Workers",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply retail-case-database --local",
    "db:migrate:remote": "wrangler d1 migrations apply retail-case-database --remote"
  },
  "devDependencies": {
    "wrangler": "^4.9.1"
  }
}
